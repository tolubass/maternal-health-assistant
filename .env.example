# Copy this file to .env and fill in your real keys.
# Never commit .env to git.

# Required: at least one LLM key must be set.
GOOGLE_API_KEY=your_google_ai_studio_key_here
GROQ_API_KEY=your_groq_api_key_here

# Optional: restrict CORS origins in production.
# Comma-separated list. Defaults to * (allow all) if not set.
# Example: CORS_ORIGINS=https://your-app.onrender.com
CORS_ORIGINS=*
